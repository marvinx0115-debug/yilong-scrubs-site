---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="2026 Catalog | Yilong Scrubs" 
  description="View our complete 2026 product catalog featuring premium medical scrubs and nursing uniforms."
>
  <div class="container mx-auto px-4 py-10 md:py-16">
    <div class="mb-6 md:mb-8">
      <h1 class="text-2xl md:text-4xl font-black italic text-slate-900">2026 Product Catalog</h1>
      <p class="text-slate-500 mt-1 md:mt-2 italic text-sm md:text-base">Premium medical scrubs and nursing uniforms collection</p>
    </div>
    
    <!-- PDF 预览（仅展示，不提供下载） -->
    <div class="bg-white rounded-2xl md:rounded-3xl shadow-2xl overflow-hidden border border-slate-100">
      <div class="w-full" style="height: calc(100vh - 200px); min-height: 500px;">
        <iframe 
          src="https://docs.google.com/gview?url=https://yilongscrubs.com/Yilong_Scrubs_Catalog_2026.pdf&embedded=true" 
          class="w-full h-full border-0"
          title="Yilong Scrubs 2026 Catalog"
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <p class="text-center text-slate-400 mt-4 text-xs italic">
      For catalog inquiries, please <a href="/contact" class="text-primary underline hover:text-blue-800">contact us</a>.
    </p>
  </div>
</Layout>