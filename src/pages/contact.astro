---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Contact Yilong Scrubs | Get a Free Quote for Medical Scrubs" 
  description="Request a free quote for medical scrubs. OEM/ODM, private label, and wholesale orders welcome. Color MOQ from 10 sets. DDP shipping available. Reply within 24 hours."
  keywords="medical scrubs quote, scrub manufacturer contact, OEM scrub factory, private label scrubs, hospital uniform supplier"
>
  <!-- Hero -->
  <section class="bg-slate-900 text-white py-14 md:py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-black mb-4">Get a Free Quote</h1>
      <p class="text-slate-300 max-w-xl mx-auto">Factory direct pricing. No agents. We respond to all inquiries within 24 hours on business days.</p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">

        <!-- Left: Quote Guide -->
        <div>
          <h2 class="text-xl md:text-2xl font-black mb-2 text-slate-900">Quote Request Guide</h2>
          <p class="text-slate-500 mb-8 text-sm">Please provide the following information so we can give you an accurate quote within 2 hours:</p>
          
          <div class="space-y-4 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">1</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Product Type</h3>
                <p class="text-slate-500 text-sm">Scrub Top / Scrub Pants / Scrub Set / Jumpsuit / Lab Coat / Custom OEM</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">2</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Quantity Per Color & Size</h3>
                <p class="text-slate-500 text-sm">Example: 20 sets/color (XS, S, M, L, XL each). We can advise on competitive minimums.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">3</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Fabric Choice</h3>
                <p class="text-slate-500 text-sm">Premium 205 GSM (brands) / Standard 180 GSM (wholesale) / Lightweight 130 GSM (budget)</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">4</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Logo / Branding</h3>
                <p class="text-slate-500 text-sm">Do you need logo customization? If yes: embroidery / screen print / heat transfer / DTG / other?</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">5</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Destination Country & City</h3>
                <p class="text-slate-500 text-sm">We provide DDP (all-inclusive) pricing for USA, Canada, Mexico, LATAM, and Middle East.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-sm flex-shrink-0">6</div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Shipping Preference</h3>
                <p class="text-slate-500 text-sm">Sea freight (15–30 days) / Air freight (5–10 days) / Express (3–5 days) / DDP service</p>
              </div>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200">
            <h3 class="font-black text-slate-900 mb-4">Prefer to Contact Directly?</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <span class="text-xl">📱</span>
                <div>
                  <p class="text-xs text-slate-400 uppercase tracking-wider font-bold">WhatsApp (Fastest)</p>
                  <a href="https://wa.me/8615556105350" target="_blank" class="text-secondary font-bold hover:underline">+86 155 5610 5350</a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xl">📧</span>
                <div>
                  <p class="text-xs text-slate-400 uppercase tracking-wider font-bold">Email</p>
                  <a href="mailto:marvin@sibaizhi.com" class="text-slate-700 font-bold hover:underline">marvin@sibaizhi.com</a>
                </div>
              </div>
              <div class="pt-3 border-t border-slate-200">
                <p class="text-xs text-slate-500">🕐 Response time: Within 24 hours on business days. For urgent orders, WhatsApp is fastest.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div>
          <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 md:p-8">
            <h2 class="text-xl font-black mb-6 text-slate-900">Send Us a Message</h2>
            <form action="https://formspree.io/f/xrerzeov" method="POST" class="space-y-5">
              
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">First Name *</label>
                  <input type="text" name="firstName" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm">
                </div>
                <div>
                  <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Last Name *</label>
                  <input type="text" name="lastName" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm">
                </div>
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Country *</label>
                <input type="text" name="country" required placeholder="e.g. United States" class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm">
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Email *</label>
                <input type="email" name="email" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm">
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">WhatsApp / Phone (Optional)</label>
                <input type="text" name="whatsapp" placeholder="e.g. +1 555 123 4567" class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm">
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Product Type</label>
                  <select name="productType" class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm bg-white">
                    <option value="">Select...</option>
                    <option>Scrub Top</option>
                    <option>Scrub Pants</option>
                    <option>Scrub Set (Top + Pants)</option>
                    <option>Jumpsuit</option>
                    <option>Lab Coat</option>
                    <option>Custom OEM / Private Label</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Target Quantity</label>
                  <select name="quantity" class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm bg-white">
                    <option value="">Select...</option>
                    <option>1–50 sets</option>
                    <option>50–200 sets</option>
                    <option>200–500 sets</option>
                    <option>500+ sets</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Logo / Branding Needed?</label>
                <div class="flex gap-6 mt-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="logoNeeded" value="Yes" class="accent-secondary w-4 h-4">
                    <span class="text-sm text-slate-700">Yes, I need logo customization</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="logoNeeded" value="No" class="accent-secondary w-4 h-4">
                    <span class="text-sm text-slate-700">No branding needed</span>
                  </label>
                </div>
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Your Message</label>
                <textarea name="message" rows="4" placeholder="Tell us about your project: target market, preferred fabric, delivery timeline, etc." class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent outline-none text-sm resize-none"></textarea>
              </div>

              <button type="submit" class="w-full bg-secondary text-white font-bold py-4 rounded-full hover:bg-emerald-700 transition shadow-lg text-base">
                Send Quote Request →
              </button>
              <p class="text-xs text-slate-400 text-center">We respond within 24 hours on business days. Form powered by Formspree.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
