---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Contact Marvin at Yilong Scrubs for wholesale medical uniforms.">
  <div class="container mx-auto px-4 py-24 text-center">
    <h1 class="text-5xl font-black mb-12 italic">Connect with Marvin</h1>
    <div class="max-w-2xl mx-auto p-12 bg-white rounded-[3rem] shadow-xl border border-slate-50">
      <p class="text-xl mb-8 font-bold italic text-primary">Ready to start your project?</p>
      <p class="mb-2 font-bold">WhatsApp: +8615556105350</p>
      <p class="mb-8 font-bold">Email: marvin@sibaizhi.com</p>
      <button class="bg-primary text-white font-black py-5 px-12 rounded-2xl text-lg uppercase tracking-widest">Get a Quote</button>
    </div>
  </div>
</Layout>