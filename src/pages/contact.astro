---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Connect with Yilong | Wholesale & Custom Scrub Inquiries" 
  description="Contact Yilong Scrubs for wholesale medical uniforms, OEM/ODM inquiries, and custom scrub manufacturing. Get a fast response via WhatsApp or Email."
  keywords="contact scrub manufacturer, custom scrub quote, wholesale medical apparel inquiry"
>
  <div class="container mx-auto px-4 py-24 text-center">
    <h1 class="text-5xl font-black mb-12 italic">Connect with Yilong</h1>
    <div class="max-w-2xl mx-auto p-12 bg-white rounded-[3rem] shadow-xl border border-slate-50">
      <p class="text-xl mb-8 font-bold italic text-primary">Ready to start your custom nursing scrubs project?</p>
      <div class="space-y-4">
        <p class="font-bold flex items-center justify-center gap-3">
          <span class="text-secondary">WhatsApp:</span> 
          <a href="https://wa.me/8615556105350" class="hover:text-primary transition">+8615556105350</a>
        </p>
        <p class="font-bold flex items-center justify-center gap-3 mb-8">
          <span class="text-secondary">Email:</span> 
          <a href="mailto:marvin@sibaizhi.com" class="hover:text-primary transition">marvin@sibaizhi.com</a>
        </p>
      </div>
      <a href="https://wa.me/8615556105350" target="_blank" class="inline-block bg-primary text-white font-black py-5 px-12 rounded-2xl text-lg uppercase tracking-widest hover:bg-blue-800 transition shadow-lg mt-8">Get a Fast Quote</a>
    </div>
  </div>
</Layout>