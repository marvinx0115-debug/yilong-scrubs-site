---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact Marvin at Yilong Scrubs for wholesale medical uniforms, OEM/ODM inquiries, and custom scrub manufacturing.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-extrabold mb-8 text-center italic">Connect with Marvin</h1>
    <p class="text-slate-500 mb-20 text-center max-w-2xl mx-auto text-lg">Ready to start your project or need a catalog? Reach out to us today for a personalized consultation.</p>
    
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <div class="space-y-12">
        <div class="p-10 bg-white border border-slate-100 rounded-[2rem] shadow-sm">
          <h3 class="text-2xl font-bold mb-8 italic">Contact Details</h3>
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="bg-primary/10 p-3 rounded-xl text-primary font-bold">@</div>
              <p><span class="block text-xs font-bold uppercase text-slate-400 tracking-widest">Email</span> marvin@sibaizhi.com</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="bg-primary/10 p-3 rounded-xl text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <p><span class="block text-xs font-bold uppercase text-slate-400 tracking-widest">WhatsApp / Phone</span> +8615556105350</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="bg-primary/10 p-3 rounded-xl text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <p><span class="block text-xs font-bold uppercase text-slate-400 tracking-widest">Factory Address</span> Anhui, China</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="bg-white p-12 rounded-[3rem] shadow-xl border border-slate-50">
        <h3 class="text-2xl font-bold mb-8 italic">Quick Inquiry</h3>
        <form class="space-y-6">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold uppercase text-slate-400 tracking-widest mb-2">First Name</label>
              <input type="text" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="John" />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-slate-400 tracking-widest mb-2">Last Name</label>
              <input type="text" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="Doe" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase text-slate-400 tracking-widest mb-2">Work Email</label>
            <input type="email" class="w-full bg-slate-50 border-none rounded-xl p-4 focus:ring-2 focus:ring-primary" placeholder="john@company.com" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase text-slate-400 tracking-widest mb-2">Message</label>
            <textarea class="w-full bg-slate-50 border-none rounded-xl p-4 h-32 focus:ring-2 focus:ring-primary" placeholder="Tell us about your project..."></textarea>
          </div>
          <button type="button" class="w-full bg-primary text-white font-black py-5 rounded-2xl hover:bg-blue-800 transition shadow-lg text-lg uppercase tracking-widest">Send Request</button>
        </form>
      </div>
    </div>
  </div>
</Layout>
