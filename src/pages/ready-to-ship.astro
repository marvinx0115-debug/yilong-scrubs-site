---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Ready to Ship (RTS) Scrubs | Fast Wholesale Delivery | Yilong Scrubs" 
  description="Need scrubs fast? Browse our Ready to Ship collection. High-quality 72/21/7 medical scrubs in stock for immediate global dispatch. No long lead times."
  keywords="ready to ship scrubs, RTS medical uniforms, fast delivery scrubs, wholesale scrubs in stock"
>
  <div class="container mx-auto px-4 py-16 md:py-24">
    <div class="max-w-4xl mx-auto text-center mb-20">
      <div class="inline-block px-6 py-2 bg-secondary text-white font-black uppercase tracking-[0.3em] text-xs rounded-full mb-8 italic">Fast Dispatch</div>
      <h1 class="text-4xl md:text-7xl font-black italic text-slate-900 leading-tight mb-8">Ready to Ship.</h1>
      <p class="text-xl text-slate-500 italic leading-relaxed">Skip the manufacturing lead time. Our most popular styles and colors are in stock and ready for immediate global shipping.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 mb-32">
      <!-- RTS Item 1 -->
      <div class="group">
        <div class="aspect-[3/4] bg-slate-100 rounded-[2rem] overflow-hidden mb-6 relative">
          <img src="https://sc02.alicdn.com/kf/A5cf89e66f8724400a9dff9b9bac7cd03O.png" alt="RTS Navy Blue Scrub Set" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute top-6 left-6 bg-secondary text-white px-4 py-1 rounded-full font-bold text-[10px] uppercase tracking-widest italic shadow-lg">In Stock</div>
        </div>
        <h3 class="text-2xl font-black italic text-slate-900 mb-2">Elite V-Neck Set - Navy</h3>
        <p class="text-slate-500 italic mb-4">72/21/7 Premium Fabric</p>
        <p class="font-bold text-primary italic">Ships in 48 Hours</p>
      </div>

      <!-- RTS Item 2 -->
      <div class="group">
        <div class="aspect-[3/4] bg-slate-100 rounded-[2rem] overflow-hidden mb-6 relative">
          <img src="https://sc02.alicdn.com/kf/A7e11502b0045464da109007ec18708f30.png" alt="RTS Burgundy Scrub Set" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute top-6 left-6 bg-secondary text-white px-4 py-1 rounded-full font-bold text-[10px] uppercase tracking-widest italic shadow-lg">In Stock</div>
        </div>
        <h3 class="text-2xl font-black italic text-slate-900 mb-2">Modern Jogger Set - Burgundy</h3>
        <p class="text-slate-500 italic mb-4">4-Way Stretch Performance</p>
        <p class="font-bold text-primary italic">Ships in 48 Hours</p>
      </div>

      <!-- RTS Item 3 -->
      <div class="group">
        <div class="aspect-[3/4] bg-slate-100 rounded-[2rem] overflow-hidden mb-6 relative">
          <img src="https://sc02.alicdn.com/kf/Afa9b2c28a97f47c5892c840728a7e217Y.png" alt="RTS Charcoal Grey Jumpsuit" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute top-6 left-6 bg-secondary text-white px-4 py-1 rounded-full font-bold text-[10px] uppercase tracking-widest italic shadow-lg">In Stock</div>
        </div>
        <h3 class="text-2xl font-black italic text-slate-900 mb-2">Signature Jumpsuit - Charcoal</h3>
        <p class="text-slate-500 italic mb-4">One-Piece Professional Elite</p>
        <p class="font-bold text-primary italic">Ships in 48 Hours</p>
      </div>
    </div>

    <div class="bg-slate-900 text-white p-10 md:p-20 rounded-[4rem] text-center shadow-2xl">
      <h2 class="text-3xl md:text-5xl font-black mb-8 italic">Need a custom wholesale quote?</h2>
      <p class="text-xl italic text-slate-400 mb-12">Whether you need 10 sets or 10,000, Yilong Team provides the same level of precision and care.</p>
      <a href="/contact" class="inline-block bg-primary text-white font-black py-6 px-16 rounded-full text-xl uppercase tracking-widest hover:bg-blue-800 transition shadow-2xl">Get Fast Quote</a>
    </div>
  </div>
</Layout>
