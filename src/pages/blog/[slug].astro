---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = [
    {
      slug: "why-72-21-7-is-best",
      title: "Why 72/21/7 is the Best Fabric for Medical Scrubs",
      date: "April 10, 2026",
      keywords: "72% Polyester 21% Rayon 7% Spandex, medical scrub fabric, healthcare uniform material",
      description: "Discover why the 72/21/7 blend is the gold standard for premium medical scrubs.",
      content: `<p>In the demanding world of healthcare, a uniform is more than just clothing—it's professional gear. At Yilong Scrubs, we've spent two decades testing various textile combinations, and one ratio consistently stands above the rest: 72% Polyester, 21% Rayon, and 7% Spandex.</p>
      <h2 class='text-2xl font-bold mt-8 mb-4'>The Performance Breakdown</h2>
      <p>Polyester provides durability, Rayon offers silk-like softness, and Spandex ensures 4-way stretch movement.</p>`
    },
    {
      slug: "future-of-ai-in-manufacturing",
      title: "The Future of AI in Garment Manufacturing",
      date: "December 15, 2025",
      keywords: "AI garment manufacturing, smart factory, medical apparel trends",
      description: "How artificial intelligence is revolutionizing the production of medical scrubs.",
      content: `<p>As we close out 2025, the integration of AI in our Anhui facility has reached new heights. From predictive maintenance of sewing machines to AI-driven fabric cutting optimization, technology is ensuring higher precision and less waste.</p>`
    },
    {
      slug: "procurement-for-small-clinics",
      title: "Smart Procurement Strategies for Small Clinics",
      date: "June 20, 2025",
      keywords: "clinic procurement, medical uniform wholesale, small clinic scrubs",
      description: "Efficient ways for small medical practices to source high-quality uniforms.",
      content: `<p>Small clinics often struggle with high MOQs from large factories. At Yilong, our flexible 10-set MOQ is designed specifically to help private practices maintain a professional look without the burden of excess inventory.</p>`
    },
    {
      slug: "fabric-science-polyester-vs-rayon",
      title: "Fabric Science: The Battle Between Polyester and Rayon",
      date: "December 10, 2024",
      keywords: "polyester vs rayon, medical apparel fabric, scrubs material science",
      description: "An in-depth look at the fibers that make up your daily work uniform.",
      content: `<p>Why choose one when you can have both? While pure polyester is durable but can be stiff, rayon adds the essential moisture-wicking and softness properties that medical professionals need for 12-hour shifts.</p>`
    },
    {
      slug: "hospital-color-trends-2024",
      title: "Emerging Hospital Color Trends for 2024",
      date: "June 15, 2024",
      keywords: "scrub colors, hospital uniform trends, medical fashion 2024",
      description: "Moving beyond basic blue: the rise of Sage Green and Charcoal Grey in healthcare.",
      content: `<p>2024 has seen a shift towards earthy tones. Sage Green and Charcoal are becoming the preferred choices for modern dental and aesthetic clinics, moving away from the clinical 'hospital blue' of the past.</p>`
    },
    {
      slug: "reducing-lead-times-strategy",
      title: "Strategy: How We Reduced Lead Times by 30%",
      date: "December 20, 2023",
      keywords: "manufacturing lead times, scrubs production, efficient sourcing",
      description: "Yilong's commitment to faster delivery for global healthcare brands.",
      content: `<p>By optimizing our raw material supply chain in Anhui, we've successfully reduced our bulk delivery times to 15-30 days, ensuring our clients never miss a market opportunity.</p>`
    },
    {
      slug: "balancing-cost-and-quality",
      title: "Balancing Cost and Quality in Medical Apparel",
      date: "June 10, 2023",
      keywords: "scrubs quality control, cost-effective medical uniforms, factory direct scrubs",
      description: "How to avoid the trap of cheap, low-quality scrubs that fail after five washes.",
      content: `<p>Price is what you pay; value is what you get. We explain why investing in higher GSM fabrics like our 205GSM Elite series saves money in the long run through durability and color fastness.</p>`
    },
    {
      slug: "branding-your-scrub-startup",
      title: "A Beginner's Guide to Branding Your Scrub Startup",
      date: "December 15, 2022",
      keywords: "start a scrub brand, custom labels, medical apparel branding",
      description: "How to move from generic uniforms to a recognized healthcare brand.",
      content: `<p>Branding is more than just a logo. It's the neck label, the hangtag, and the custom packaging. Yilong Scrubs provides full OEM support to help new brands establish their identity.</p>`
    },
    {
      slug: "sustainable-manufacturing-healthcare",
      title: "The Shift Towards Sustainable Manufacturing in Healthcare",
      date: "June 25, 2022",
      keywords: "sustainable scrubs, eco-friendly medical apparel, OEKO-TEX certified",
      description: "Why OEKO-TEX certification is the first step toward a greener medical industry.",
      content: `<p>Sustainability starts with safety. By ensuring all our fabrics are free from harmful chemicals, we protect both the medical professional and the environment.</p>`
    },
    {
      slug: "sourcing-medical-apparel-guide",
      title: "Global Guide: Sourcing Medical Apparel from China",
      date: "December 12, 2021",
      keywords: "source scrubs from China, medical garment factory, wholesale guide",
      description: "Essential tips for international buyers looking for reliable manufacturing partners.",
      content: `<p>Finding a reliable factory in China requires more than just an Alibaba search. You need a partner with a proven 20-year track record and specialized QC processes.</p>`
    },
    {
      slug: "evolution-from-cotton-to-stretch",
      title: "The Evolution: From Traditional Cotton to 4-Way Stretch",
      date: "June 18, 2021",
      keywords: "stretch scrubs, cotton vs spandex, medical uniform history",
      description: "How fabric technology changed the way doctors and nurses work.",
      content: `<p>The days of stiff, boxy cotton scrubs are over. The industry has shifted to high-performance stretch blends that allow for a full range of motion during emergency procedures.</p>`
    },
    {
      slug: "antimicrobial-fabrics-new-standard",
      title: "Antimicrobial Fabrics: The New Standard in 2020",
      date: "December 20, 2020",
      keywords: "antimicrobial scrubs, infection control uniforms, healthcare safety",
      description: "Why silver-ion treatments became essential for hospital uniforms this year.",
      content: `<p>2020 changed everything. The demand for specialized antimicrobial finishing skyrocketed, leading Yilong to innovate new silver-ion fabric treatments for enhanced safety.</p>`
    },
    {
      slug: "managing-supply-chain-crisis-2020",
      title: "Resilience: Managing the Supply Chain Crisis of 2020",
      date: "June 15, 2020",
      keywords: "supply chain resilience, manufacturing crisis, medical apparel delivery",
      description: "How Yilong maintained production and delivery during a global pandemic.",
      content: `<p>Despite global disruptions, our vertical integration and strong raw material partnerships allowed us to continue serving our global clients during the most challenging year in modern history.</p>`
    }
  ];

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout 
  title={`${post.title} | Yilong Scrubs Blog`} 
  description={post.description}
  keywords={post.keywords}
>
  <article class="container mx-auto px-4 py-16 md:py-24 max-w-4xl">
    <a href="/blog" class="text-primary font-bold uppercase text-[10px] md:text-xs tracking-widest hover:underline mb-8 md:mb-12 inline-block italic">← Back to Insights</a>
    
    <header class="mb-12 md:mb-16 text-left">
      <p class="text-xs md:text-sm font-bold text-secondary uppercase tracking-widest mb-4 italic">{post.date}</p>
      <h1 class="text-3xl md:text-6xl font-black italic text-slate-900 leading-tight">{post.title}</h1>
    </header>

    <div class="prose prose-lg md:prose-xl prose-slate max-w-none text-slate-700 leading-relaxed italic" set:html={post.content}>
    </div>
    
    <div class="mt-20 pt-10 border-t border-slate-100">
      <div class="bg-primary text-white p-8 md:p-12 rounded-[2rem] md:rounded-[3rem] text-center shadow-2xl">
        <h3 class="text-2xl font-black mb-4 italic">Ready to work with a proven specialist?</h3>
        <p class="mb-8 italic opacity-90">Yilong Scrubs has been perfecting medical apparel since 2006. Let's discuss your next collection.</p>
        <a href="/contact" class="inline-block bg-secondary px-8 py-3 rounded-full font-bold uppercase text-xs tracking-widest hover:bg-emerald-600 transition shadow-lg">Get a Quote</a>
      </div>
    </div>
  </article>
</Layout>