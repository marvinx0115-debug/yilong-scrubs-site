---
<Layout 
  title="Industry Insights & Blog | Yilong Scrubs" 
  description="Stay updated with the latest trends in medical apparel, fabric technology, and wholesale sourcing tips from Yilong Scrubs experts since 2020."
  keywords="medical scrubs blog, nursing uniform trends, fabric technology insights, healthcare apparel manufacturing"
>
  <div class="container mx-auto px-4 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-black mb-16 text-center italic text-slate-900 leading-tight">Industry Insights</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 max-w-5xl mx-auto">
      {posts.map(post => (
        <article class="bg-white rounded-[2rem] md:rounded-[3rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all border border-slate-100 group">
          <div class="bg-slate-50 h-48 md:h-56 relative overflow-hidden flex items-center justify-center">
             <div class="absolute inset-0 bg-primary/5 group-hover:bg-primary/10 transition-colors"></div>
             <span class="text-primary/20 text-6xl font-black italic select-none">YILONG</span>
          </div>
          <div class="p-8 md:p-10">
            <p class="text-[10px] md:text-xs font-bold text-secondary uppercase tracking-widest mb-3 italic">{post.date}</p>
            <h2 class="text-2xl md:text-3xl font-black mb-4 italic leading-tight text-slate-900 group-hover:text-primary transition-colors underline decoration-transparent group-hover:decoration-primary underline-offset-4">{post.title}</h2>
            <p class="text-base md:text-lg text-slate-600 mb-6 italic line-clamp-3">{post.excerpt}</p>
            <a href={`/blog/${post.slug}`} class="text-primary font-bold uppercase text-[10px] md:text-xs tracking-widest hover:underline italic flex items-center gap-2">
              Read Deep Dive <span class="group-hover:translate-x-2 transition-transform">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>