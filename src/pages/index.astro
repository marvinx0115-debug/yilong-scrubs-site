---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Yilong Scrubs | 20-Year Medical Scrubs Manufacturer & Wholesale Supplier" 
  description="Premium nursing scrubs manufacturer since 2006. 100% focused on high-quality 4-way stretch hospital uniforms. Low MOQ & OEM/ODM services for global healthcare brands."
  keywords="medical scrubs manufacturer, nursing scrubs wholesale, hospital uniform factory, custom medical scrubs, 20 year garment factory"
>
  <section class="relative h-[700px] flex items-center bg-primary text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://sc02.alicdn.com/kf/Aa8c317d768c143bf98a8a63a6a5de8f34.png" alt="Wholesale Medical Scrubs Manufacturer Team" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent opacity-95"></div>
    </div>
    <div class="container mx-auto px-4 z-10 py-20 md:py-0">
      <div class="inline-block px-4 py-1 bg-secondary text-white font-bold rounded-full text-xs mb-6 uppercase tracking-widest italic animate-pulse">Factory Direct Sourcing</div>
      <h1 class="text-4xl md:text-7xl font-extrabold mb-6 leading-tight italic">20 Years of Precision.<br/><span class="text-secondary underline decoration-4 underline-offset-8">100% Focused</span> on Your Comfort.</h1>
      <p class="text-lg md:text-xl max-w-2xl mb-10 text-slate-100 leading-relaxed">
        Yilong Scrubs: Discover professional-grade medical scrubs and nursing uniforms engineered for performance, durability, and a perfect fit. Crafted with OEKO-TEX® certified fabrics.
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-4">
        <a href="/products" class="bg-secondary px-8 md:px-10 py-4 rounded-full font-bold text-base md:text-lg hover:bg-emerald-600 transition shadow-lg text-center">Explore Collections</a>
        <a href="/Yilong_Scrubs_Catalog_2026.pdf" download class="bg-white text-primary px-8 md:px-10 py-4 rounded-full font-bold text-base md:text-lg hover:bg-slate-100 transition shadow-lg text-center flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download 2026 Catalog
        </a>
      </div>
    </div>
  </section>

  <!-- Data Counters Section (Learned from Fuyi Group) -->
  <section class="py-12 bg-slate-900 text-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl md:text-5xl font-black text-secondary mb-2 italic">20+</div>
          <p class="text-[10px] md:text-xs text-slate-400 font-bold uppercase tracking-[0.2em]">Years of Expertise</p>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-black text-secondary mb-2 italic">80+</div>
          <p class="text-[10px] md:text-xs text-slate-400 font-bold uppercase tracking-[0.2em]">Global Markets</p>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-black text-secondary mb-2 italic">500k+</div>
          <p class="text-[10px] md:text-xs text-slate-400 font-bold uppercase tracking-[0.2em]">Monthly Capacity</p>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-black text-secondary mb-2 italic">100%</div>
          <p class="text-[10px] md:text-xs text-slate-400 font-bold uppercase tracking-[0.2em]">Scrubs Specialist</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4 italic text-slate-900">Premium Nursing Scrubs Solutions</h2>
      <p class="text-slate-500 mb-16 text-lg italic">Building trust through quality and reliability for over two decades.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-xl font-bold mb-4 italic text-primary">20-Year Heritage</h3>
          <p class="text-slate-600 italic">Two decades of specialized manufacturing experience in the global medical apparel market.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-xl font-bold mb-4 italic text-primary">100% Scrubs Focus</h3>
          <p class="text-slate-600 italic">We don't just make uniforms; we specialize exclusively in hospital scrubs and nursing wear.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-xl font-bold mb-4 italic text-primary">Flexible Low MOQ</h3>
          <p class="text-slate-600 italic">Starting from 10-50 sets, making professional custom nursing scrubs accessible for startups.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm hover:shadow-xl transition-all">
          <h3 class="text-xl font-bold mb-4 italic text-primary">Certified Safety</h3>
          <p class="text-slate-600 italic">All nursing uniform fabrics are OEKO-TEX® Standard 100 certified for safety.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
