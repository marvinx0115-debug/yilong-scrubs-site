---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home" description="Yilong Scrubs - 20 Years of Precision. 100% Focused on Your Comfort.">
  <section class="relative h-[650px] flex items-center bg-primary text-white overflow-hidden">
    <div class="container mx-auto px-4 z-10">
      <h1 class="text-6xl font-extrabold mb-6 leading-tight italic">20 Years of Precision.<br/><span class="text-secondary underline decoration-4 underline-offset-8">100% Focused</span> on Your Comfort.</h1>
      <p class="text-xl max-w-2xl mb-10 text-slate-100 leading-relaxed">
        Discover professional-grade medical scrubs engineered for performance, durability, and a perfect fit. Crafted with OEKO-TEX® certified fabrics and a legacy of manufacturing excellence.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/products" class="bg-secondary px-10 py-4 rounded-full font-bold text-lg hover:bg-emerald-600 transition shadow-lg">Explore Collections</a>
        <a href="/contact" class="border-2 border-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-primary transition">Get a Custom Quote</a>
      </div>
    </div>
  </section>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4 italic">The Yilong Difference</h2>
      <p class="text-slate-500 mb-16 text-lg">Building trust through quality and reliability for over two decades.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic">20-Year Heritage</h3>
          <p class="text-slate-600">Two decades of specialized manufacturing experience in the global medical apparel market.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic">100% Scrubs Focus</h3>
          <p class="text-slate-600">We don't just make uniforms; we specialize exclusively in scrubs.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic">Flexible Low MOQ</h3>
          <p class="text-slate-600">Starting from 10-50 sets, making professional customization accessible.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic">Certified Safety</h3>
          <p class="text-slate-600">All fabrics are OEKO-TEX® Standard 100 certified.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>