---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Yilong Scrubs | 20-Year Medical Scrubs Manufacturer & Wholesale Supplier" 
  description="Premium nursing scrubs manufacturer since 2006. 100% focused on high-quality 4-way stretch hospital uniforms. Low MOQ & OEM/ODM services for global healthcare brands."
  keywords="medical scrubs manufacturer, nursing scrubs wholesale, hospital uniform factory, custom medical scrubs, 20 year garment factory"
>
  <section class="relative h-[650px] flex items-center bg-primary text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://sc02.alicdn.com/kf/Aa8c317d768c143bf98a8a63a6a5de8f34.png" alt="Wholesale Medical Scrubs Manufacturer Team" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent opacity-95"></div>
    </div>
    <div class="container mx-auto px-4 z-10">
      <h1 class="text-6xl font-extrabold mb-6 leading-tight italic">20 Years of Precision.<br/><span class="text-secondary underline decoration-4 underline-offset-8">100% Focused</span> on Your Comfort.</h1>
      <p class="text-xl max-w-2xl mb-10 text-slate-100 leading-relaxed">
        Yilong Scrubs: Discover professional-grade medical scrubs and nursing uniforms engineered for performance, durability, and a perfect fit. Crafted with OEKO-TEX® certified fabrics.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/products" class="bg-secondary px-10 py-4 rounded-full font-bold text-lg hover:bg-emerald-600 transition shadow-lg">Explore Collections</a>
        <a href="/contact" class="border-2 border-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-primary transition">Get a Custom Quote</a>
      </div>
    </div>
  </section>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4 italic text-slate-900">Premium Nursing Scrubs Solutions</h2>
      <p class="text-slate-500 mb-16 text-lg">Building trust through quality and reliability for over two decades.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic text-primary">20-Year Heritage</h3>
          <p class="text-slate-600">Two decades of specialized manufacturing experience in the global medical apparel market.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic text-primary">100% Scrubs Focus</h3>
          <p class="text-slate-600">We don't just make uniforms; we specialize exclusively in hospital scrubs and nursing wear.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic text-primary">Flexible Low MOQ</h3>
          <p class="text-slate-600">Starting from 10-50 sets, making professional custom nursing scrubs accessible for startups.</p>
        </div>
        <div class="p-10 border border-slate-100 rounded-3xl shadow-sm">
          <h3 class="text-xl font-bold mb-4 italic text-primary">Certified Safety</h3>
          <p class="text-slate-600">All nursing uniform fabrics are OEKO-TEX® Standard 100 certified for safety.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>