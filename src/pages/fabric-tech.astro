---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Fabric & Tech" description="Advanced fabric technology for medical scrubs.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-bold mb-16 text-center italic">Fabric Technology</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="bg-white p-12 rounded-3xl border border-slate-100">
        <h2 class="text-2xl font-bold mb-6 italic text-primary">4-Way Stretch</h2>
        <p class="text-lg text-slate-600 leading-relaxed">Move freely without restriction. Our scrubs adapt to your body’s every movement.</p>
      </div>
      <div class="bg-white p-12 rounded-3xl border border-slate-100">
        <h2 class="text-2xl font-bold mb-6 italic text-secondary">OEKO-TEX® Certified</h2>
        <p class="text-lg text-slate-600 leading-relaxed">Every yard of Yilong fabric is certified to be free from harmful chemicals.</p>
      </div>
    </div>
  </div>
</Layout>