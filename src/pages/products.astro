---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Products" description="Explore Yilong Scrubs range of premium medical uniforms.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-bold mb-20 text-center italic">Collection Categorization</h1>
    <div class="space-y-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold mb-6 italic">205GSM Elite</h2>
          <p class="text-xl text-slate-700 italic mb-6 text-primary">Heavy-duty performance meets premium comfort.</p>
          <p class="text-slate-600 mb-8 leading-relaxed text-lg">Ideal for Surgeons, Emergency Response teams, and high-intensity environments.</p>
        </div>
        <div class="bg-slate-100 aspect-square rounded-[3rem]"></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="bg-slate-100 aspect-square rounded-[3rem]"></div>
        <div>
          <h2 class="text-4xl font-bold mb-6 italic">180GSM Versatile</h2>
          <p class="text-xl text-slate-700 italic mb-6 text-secondary">The gold standard of modern medical apparel.</p>
          <p class="text-slate-600 mb-8 leading-relaxed text-lg">Ideal for General nursing, dental clinics, and everyday wear.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>