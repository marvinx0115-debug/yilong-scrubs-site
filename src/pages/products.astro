---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nursing Scrubs Collections" description="Explore Yilong Scrubs range of professional nursing scrub sets. Model-featured uniforms with premium fabric compositions.">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-5xl font-black mb-8 text-center italic">Nursing Scrub Collections</h1>
    <p class="text-slate-500 mb-20 text-center max-w-2xl mx-auto text-lg">Engineered for the modern healthcare professional. Combining ergonomic design with 20 years of manufacturing excellence.</p>
    
    <div class="space-y-32">
      <!-- Elite Series -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-4 py-1 bg-primary/10 text-primary font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic">Elite Series</div>
          <h2 class="text-4xl font-black mb-6 italic">Premium Jogger Scrub Set</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic">The pinnacle of style and function. Our Elite Joggers are designed for healthcare professionals who prioritize both performance and a modern silhouette.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3">Professional Specs</h4>
            <p class="text-lg font-bold text-primary italic">72% Polyester / 21% Rayon / 7% Spandex</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 205GSM | Style: Modern Jogger Fit | Features: 4-Way Stretch, Multi-Pocket Design</p>
          </div>
          
          <p class="font-bold text-slate-900 border-l-4 border-primary pl-4 italic">Available in: Burgundy, Navy, Charcoal, and Hunter Green.</p>
        </div>
        <div class="aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A7e11502b0045464da109007ec18708f30.png" alt="Burgundy Jogger Scrub Set" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic">Burgundy Collection</div>
        </div>
      </div>

      <!-- Versatile Series -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A5cf89e66f8724400a9dff9b9bac7cd03O.png" alt="Royal Blue Classic Scrub Set" class="w-full h-full object-cover" />
          <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-2 rounded-xl text-xs font-bold uppercase italic">Royal Blue Collection</div>
        </div>
        <div class="order-1 lg:order-2 text-right lg:text-left">
          <div class="inline-block px-4 py-1 bg-secondary/10 text-secondary font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic">Versatile Series</div>
          <h2 class="text-4xl font-black mb-6 italic">Classic V-Neck Scrub Set</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic">The industry gold standard. A timeless design combined with modern moisture-wicking technology for the everyday healthcare hero.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3">Professional Specs</h4>
            <p class="text-lg font-bold text-secondary italic">Polyester / Spandex Performance Blend</p>
            <p class="text-sm text-slate-500 mt-2 italic">Weight: 180GSM | Style: Traditional V-Neck | Features: Easy Care, Wrinkle-Resistant</p>
          </div>
          
          <p class="font-bold text-slate-900 border-r-4 lg:border-r-0 lg:border-l-4 border-secondary pr-4 lg:pr-0 lg:pl-4 italic">Best for: General Nursing, Dental Clinics, and Hospital Teams.</p>
        </div>
      </div>

      <!-- Team/Bulk Collection -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-4 py-1 bg-blue-100 text-blue-600 font-bold rounded-full text-xs mb-4 uppercase tracking-widest italic">Team Solutions</div>
          <h2 class="text-4xl font-black mb-6 italic">Institutional & Bulk Collections</h2>
          <p class="text-xl text-slate-700 mb-8 leading-relaxed italic">Coordinated professional looks for entire hospital departments or private practices. High-durability uniforms built for daily laundering.</p>
          
          <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100">
            <h4 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-3">Bulk Order Specs</h4>
            <p class="text-lg font-bold text-blue-500 italic">OEKO-TEX® Certified Fabric Base</p>
            <p class="text-sm text-slate-500 mt-2 italic">MOQ: 10 sets/color | Custom Logo Options: 20 sets | Fast Lead Time: 15-30 Days</p>
          </div>
          
          <p class="font-bold text-slate-900 border-l-4 border-blue-400 pl-4 italic">Customizable for your brand's unique identity.</p>
        </div>
        <div class="aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl relative">
          <img src="https://sc02.alicdn.com/kf/A990ecf6da0714ad282a61ab8316c3210S.png" alt="Medical Team in Scrubs" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</Layout>