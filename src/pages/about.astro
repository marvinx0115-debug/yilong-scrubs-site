---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About Us" description="Yilong Scrubs - 20 years of medical apparel manufacturing expertise.">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-6xl font-black mb-12 italic">20 Years of Craftsmanship</h1>
      <p class="text-2xl text-slate-700 leading-relaxed mb-12">Born in the heart of professional garment manufacturing, Yilong Scrubs has spent 20 years perfecting the art of the medical uniform.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-slate-50 p-12 rounded-[2rem]">
          <h3 class="font-bold text-xl mb-4 italic">Global Reach</h3>
          <p class="text-slate-600">Serving healthcare brands in North America, Europe, and Australia.</p>
        </div>
        <div class="bg-slate-50 p-12 rounded-[2rem]">
          <h3 class="font-bold text-xl mb-4 italic">Factory Direct</h3>
          <p class="text-slate-600">No middlemen. Direct access to 20 years of manufacturing know-how.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>