            <p class="text-xs text-slate-400 mb-1">WhatsApp (Fastest Response)</p>
            <a href="https://wa.me/8615556105350" target="_blank" class="text-secondary font-bold hover:underline">+86 155 5610 5350</a>
          </div>
          <div>
            <p class="text-xs text-slate-400 mb-1">Email</p>
            <a href="mailto:marvin@sibaizhi.com" class="text-slate-300 hover:text-white transition">marvin@sibaizhi.com</a>
          </div>
