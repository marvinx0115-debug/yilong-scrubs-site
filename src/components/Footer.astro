          <li><a href="/products" class="hover:text-white transition">Jogger Scrubs</a></li>
          <li><a href="/products" class="hover:text-white transition">Lab Coats</a></li>
          <li><a href="/products" class="hover:text-white transition">Premium Series (205 GSM)</a></li>
          <li><a href="/products" class="hover:text-white transition">Standard Series (180 GSM)</a></li>
          <li><a href="/products" class="hover:text-white transition">Custom OEM/ODM / Private Label</a></li>
