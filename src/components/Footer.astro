        <ul class="space-y-2 md:space-y-3 text-sm">
          <li><a href="/about-us" class="hover:text-white transition">About Yilong</a></li>
          <li><a href="/fabric-technology" class="hover:text-white transition">Fabric Technology</a></li>
          <li><a href="/services" class="hover:text-white transition">OEM/ODM Services</a></li>
          <li><a href="/size-guide" class="hover:text-white transition">Size Guide</a></li>
          <li><a href="/contact" class="hover:text-white transition">Get a Quote</a></li>
