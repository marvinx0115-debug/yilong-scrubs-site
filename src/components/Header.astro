---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/fabric-tech', label: 'Fabric & Tech' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About Us' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container mx-auto px-4 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-bold text-primary italic">Yilong Scrubs</a>
    <nav class="hidden md:flex space-x-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-slate-600 hover:text-primary font-bold uppercase text-xs tracking-widest transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>